import "@fontsource-variable/geist/index.css";
import "../styles/global.css";
---
<html lang="zh-CN"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width"/><meta name="robots" content="noindex"/><link rel="icon" type="image/svg+xml" href="/favicon.svg"/><title>404 — Rongyi / Yi盘</title></head><body><main class="not-found"><p>404 / PAGE NOT FOUND</p><h1>这个页面不存在。</h1><a class="button primary" href="/">返回主页 <span>←</span></a></main></body></html>
<style>.not-found{width:min(calc(100% - 32px),900px);min-height:100dvh;margin:auto;display:grid;place-content:center;justify-items:start}.not-found p{color:var(--accent);font:11px ui-monospace,monospace;letter-spacing:.16em}.not-found h1{max-width:700px;margin:18px 0 38px;font-size:clamp(43px,7vw,84px);line-height:1.05;letter-spacing:-.06em}</style>
