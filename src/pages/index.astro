---
import "@fontsource-variable/geist/index.css";
import "../styles/global.css";
import { projects } from "../data/projects";
import { buildLog } from "../data/build-log";
import githubStatus from "../data/github-status.json";

const refreshedAt = new Intl.DateTimeFormat("zh-CN", {
  timeZone: "Asia/Shanghai",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  hour: "2-digit",
  minute: "2-digit",
  hour12: false
}).format(new Date(githubStatus.generatedAt));

type CiSignal = {
  status: string;
  conclusion?: string | null;
  url?: string;
  headSha?: string;
  runAt?: string;
  ageHours?: number;
};

type ReleaseSignal = {
  status: string;
  tag?: string;
  url?: string;
  publishedAt?: string;
};

type ArtifactSignal = {
  status: string;
  artifacts?: Array<{ name: string; url: string; expiresAt: string; expired: boolean }>;
};

type RepositoryStatus = {
  url: string;
  headSha: string | null;
  ci: CiSignal;
  release: ReleaseSignal;
  artifact: ArtifactSignal;
};

type DisplaySignal = {
  kind: "ci" | "release" | "artifact";
  label: string;
  href: string;
  tone: "pass" | "release" | "running" | "failure" | "stale" | "neutral";
};

const repoStatus = githubStatus.repositories as Record<string, RepositoryStatus>;
const statusSourceUrl = "https://github.com/rongyishuaige7/rongyishuaige7.github.io/blob/main/scripts/fetch-github-status.mjs";

function ciSignal(signal: RepositoryStatus): DisplaySignal | null {
  const ci = signal.ci;
  const href = ci.url ?? signal.url;
  if (ci.status === "not_configured") return null;
  if (ci.status === "unknown") return { kind: "ci", label: "暂时无法确认 CI 状态", href, tone: "neutral" };
  if (ci.status === "unverified") return { kind: "ci", label: "当前版本尚未验证", href, tone: "neutral" };
  if (ci.status === "stale") return { kind: "ci", label: "CI 记录已超过 48 小时", href, tone: "stale" };
  if (ci.status === "queued" || ci.status === "in_progress" || ci.status === "requested" || ci.status === "waiting" || ci.status === "pending") {
    return { kind: "ci", label: "当前版本正在运行 CI", href, tone: "running" };
  }
  if (ci.status === "completed" && ci.conclusion === "success") return { kind: "ci", label: "当前版本 CI 通过", href, tone: "pass" };
  if (ci.status === "completed") return { kind: "ci", label: `当前版本 CI ${ci.conclusion ?? "状态未知"}`, href, tone: "failure" };
  return { kind: "ci", label: "暂时无法确认 CI 状态", href, tone: "neutral" };
}

function releaseSignal(signal: RepositoryStatus): DisplaySignal | null {
  const release = signal.release;
  if (release.status === "available" && release.tag && release.url) {
    return { kind: "release", label: `已发布 ${release.tag}`, href: release.url, tone: "release" };
  }
  if (release.status === "unknown") return { kind: "release", label: "暂时无法确认发布状态", href: signal.url, tone: "neutral" };
  return null;
}

function artifactSignal(signal: RepositoryStatus): DisplaySignal | null {
  const artifact = signal.artifact;
  const first = artifact.artifacts?.find(
    (item) => !item.expired && Number.isFinite(Date.parse(item.expiresAt)) && Date.parse(item.expiresAt) > Date.now()
  );
  if (artifact.status === "available" && first) {
    const expires = new Intl.DateTimeFormat("zh-CN", { timeZone: "Asia/Shanghai", year: "numeric", month: "2-digit", day: "2-digit" }).format(new Date(first.expiresAt));
    return { kind: "artifact", label: `固件构建产物保留至 ${expires}`, href: first.url, tone: "pass" };
  }
  if (artifact.status === "available") return { kind: "artifact", label: "固件构建产物已过期", href: signal.url, tone: "stale" };
  if (artifact.status === "expired") return { kind: "artifact", label: "固件构建产物已过期", href: signal.url, tone: "stale" };
  if (artifact.status === "unknown") return { kind: "artifact", label: "暂时无法确认构建产物", href: signal.url, tone: "neutral" };
  if (artifact.status === "unavailable" || artifact.status === "none") return { kind: "artifact", label: "当前没有固件构建产物", href: signal.url, tone: "neutral" };
  return null;
}

function primarySignal(slug: string): DisplaySignal | null {
  const signal = repoStatus[slug];
  if (!signal) return null;
  return ciSignal(signal) ?? releaseSignal(signal) ?? artifactSignal(signal);
}

function evidenceSignals(slug: string): DisplaySignal[] {
  const signal = repoStatus[slug];
  if (!signal) return [];
  return [releaseSignal(signal), ciSignal(signal), artifactSignal(signal)].filter((item): item is DisplaySignal => item !== null);
}

const title = "Rongyi — Yi盘创始人";
const description = "Rongyi 的个人主页。正在杭州开发 Yi盘，一套装在 U 盘里的随身 AI 工作台；也在做桌面工具和硬件项目。";
const siteUrl = "https://rongyishuaige7.github.io/";
const socialImage = `${siteUrl}og-card.png`;
const socialImageAlt = "Rongyi 与 Yi盘 — 让 AI 的上下文，跟着人走。";
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteUrl}#person`,
      name: "Rongyi",
      url: siteUrl,
      sameAs: ["https://github.com/rongyishuaige7"],
      jobTitle: "Founder of Yi盘",
      homeLocation: { "@type": "Place", name: "Hangzhou, China" }
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      url: siteUrl,
      name: "Rongyi / Yi盘",
      description,
      inLanguage: "zh-CN",
      publisher: { "@id": `${siteUrl}#person` }
    }
  ]
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07090d" />
    <meta name="color-scheme" content="dark" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content="Rongyi / Yi盘" />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Rongyi / Yi盘" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Rongyi / Yi盘" />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">跳到主要内容</a>
    <div class="ambient" aria-hidden="true"><i></i><i></i><i></i></div>

    <header class="site-header" data-header>
      <a class="wordmark" href="#top" aria-label="RONGYI 首页">
        <span>R</span><b>RONGYI</b><small>/ YI盘</small>
      </a>
      <nav aria-label="主导航"><a href="#work">项目</a><a href="#proof">进展</a><a href="#log">更新</a></nav>
      <a class="header-link" href="https://github.com/rongyishuaige7" target="_blank" rel="noreferrer">GITHUB <span>↗</span></a>
    </header>
    <nav class="mobile-nav" aria-label="移动端章节导航"><a href="#work">项目</a><a href="#proof">进展</a><a href="#log">更新</a></nav>

    <main id="main">
      <section class="hero" id="top" data-section="00">
        <div class="hero-copy reveal">
          <p class="eyebrow"><span class="pulse"></span> RONGYI · YI盘 · HANGZHOU</p>
          <h1><span class="headline-line">让 AI 的上下文，</span><span class="headline-line is-accent">跟着人走。</span></h1>
          <p class="hero-intro">我是 Rongyi，在杭州做 Yi盘——一套装在 U 盘里的随身 AI 工作台。长期资料、任务记录和主要产出留在盘里；我也在做桌面工具和硬件项目。</p>
          <div class="hero-actions">
            <a class="button primary" href="https://github.com/rongyishuaige7/yipan-showcase" target="_blank" rel="noreferrer">查看 Yi盘进展 <span>↗</span></a>
            <a class="button secondary" href="#work">查看项目 <span>↓</span></a>
          </div>
        </div>

        <figure class="context-machine reveal" aria-labelledby="context-machine-caption">
          <figcaption id="context-machine-caption" class="visually-hidden">功能示意：任务、长期资料与项目背景通过 Yi盘工作台供已接入的 AI 工具使用，非产品截图。</figcaption>
          <div class="machine-topline"><span>YI盘 / 工作资料流转示意</span><span class="online"><i></i> 非产品截图</span></div>
          <div class="machine-grid" aria-hidden="true">
            <div class="source-stack">
              <div class="source"><span>01</span><b>WORK</b><small>任务 / 产出</small></div>
              <div class="source"><span>02</span><b>KNOWLEDGE</b><small>长期资料</small></div>
              <div class="source"><span>03</span><b>CONTEXT</b><small>项目背景</small></div>
            </div>
            <div class="route route-left"><i class="packet packet-a"></i><i class="packet packet-b"></i></div>
            <div class="yipan-core">
              <span class="core-orbit orbit-a"></span><span class="core-orbit orbit-b"></span>
              <div class="core-mark"><span class="brand-latin">YI</span><span class="brand-cjk">盘</span></div>
              <small>PORTABLE<br />WORKSPACE</small>
            </div>
            <div class="route route-right"><i class="packet packet-c"></i></div>
            <div class="agent-stack">
              <div><i></i><b>AGENT 01</b><small>ROLE</small></div>
              <div><i></i><b>AGENT 02</b><small>ROLE</small></div>
              <div><i></i><b>AGENT 03</b><small>ROLE</small></div>
            </div>
          </div>
          <div class="machine-footer"><span>盘内资料</span><span>由用户管理</span><span>云端模型</span></div>
        </figure>

        <div class="scroll-note" aria-hidden="true"><span></span> 继续查看项目</div>
      </section>

      <section class="work section-shell" id="work" aria-labelledby="work-title" data-section="01">
        <div class="section-heading reveal">
          <div><p class="section-index">01 / PROJECTS</p><h2 id="work-title">正在做的项目</h2></div>
          <p>下面是我正在维护的公开项目。每个项目都列出当前进度、已知限制和可查看的构建记录。</p>
        </div>

        {projects.map((project) => {
          const signal = primarySignal(project.slug);
          return project.featured ? (
            <article class="project-featured reveal">
              <div class="project-main">
                <p class="eyebrow">{project.eyebrow}</p>
                <h3 class="project-title"><span class="project-title-latin">Yi</span><span class="project-title-cjk">盘</span></h3>
                <p class="project-summary">{project.summary}</p>
                <div class="tags">{project.tags.map((tag) => <span>{tag}</span>)}</div>
                <div class="project-links">
                  <a class="button primary" href={project.href} target="_blank" rel="noreferrer">查看公开仓库 <span>↗</span></a>
                  <span class="status active"><i></i>{project.status}</span>
                </div>
                {project.caveat && <p class="caveat">当前限制 · {project.caveat}</p>}
              </div>
              <figure class="yipan-blueprint" aria-labelledby="yipan-blueprint-caption">
                <figcaption id="yipan-blueprint-caption" class="visually-hidden">Yi盘功能示意图，非产品截图。</figcaption>
                <div class="blueprint-label">功能示意 · 非产品截图</div>
                <div class="drive-body">
                  <div class="drive-port"><i></i><i></i><i></i></div>
                  <div class="drive-face">
                    <b class="drive-brand"><span class="brand-latin">YI</span><span class="brand-cjk">盘</span></b><small>PORTABLE AGENT WORKSPACE</small>
                    <div class="drive-lines"><i></i><i></i><i></i></div>
                  </div>
                </div>
                <div class="capability-row"><span>INBOX</span><span>VAULT</span><span>AGENTS</span><span>BYOK</span></div>
                <div class="proof-note"><i></i> 盘内资料 · 用户管理 · 云端模型</div>
              </figure>
            </article>
          ) : (
            <article class="project-row reveal">
              <div class="project-number">{project.index}</div>
              <div class="project-copy">
                <p class="eyebrow">{project.eyebrow}</p>
                <h3>{project.name}</h3>
                <p>{project.summary}</p>
                {project.caveat && <small class="caveat">{project.caveat}</small>}
              </div>
              <div class="project-meta">
                <div class="tags">{project.tags.map((tag) => <span>{tag}</span>)}</div>
                {signal ? <a class={`live-signal ${signal.tone}`} href={signal.href} target="_blank" rel="noreferrer" data-ci-status={signal.kind === "ci" ? repoStatus[project.slug]?.ci.status : undefined} data-ci-run-at={signal.kind === "ci" ? repoStatus[project.slug]?.ci.runAt : undefined} data-artifact-status={signal.kind === "artifact" ? repoStatus[project.slug]?.artifact.status : undefined} data-artifact-expires-at={signal.kind === "artifact" ? repoStatus[project.slug]?.artifact.artifacts?.find((item) => !item.expired)?.expiresAt : undefined}><i></i><span data-signal-label>{signal.label}</span> ↗</a> : <span class="status"><i></i>{project.status}</span>}
              </div>
              <a class="project-arrow" href={project.href} target="_blank" rel="noreferrer" aria-label={`打开 ${project.name} 仓库`}><span class="project-arrow-label">仓库</span><span aria-hidden="true">↗</span></a>
            </article>
          );
        })}
        <p class="data-note reveal">以上 GitHub 状态更新于 {refreshedAt} CST。CI 只检查指定工作流和当前默认分支；失败、过期或无法确认时会直接标出。<a href={statusSourceUrl} target="_blank" rel="noopener noreferrer">查看检查方法 ↗</a></p>
      </section>

      <section class="proof section-shell" id="proof" aria-labelledby="proof-title" data-section="02">
        <div class="proof-copy reveal">
          <p class="section-index">02 / GITHUB STATUS</p>
          <h2 id="proof-title"><span class="headline-line">少一点宣称，</span><span class="headline-line">多一点<span class="is-accent">可检查的证据。</span></span></h2>
          <p>版本、CI 和构建产物直接来自 GitHub。点击即可查看对应的发布、运行记录或下载期限。</p>
          <a class="text-link" href="https://github.com/rongyishuaige7" target="_blank" rel="noreferrer">查看全部公开仓库 ↗</a>
        </div>
        <div class="signal-panel reveal">
          <div class="signal-header"><span>GITHUB 状态快照</span><small>截至 {refreshedAt} CST</small></div>
          {projects.flatMap((project) => {
            const signals = evidenceSignals(project.slug);
            if (signals.length === 0) {
              const label = project.slug === "yipan" ? "产品事实与路线图已公开" : "尚未配置自动检查";
              return [<a class="signal-row neutral" href={project.href} target="_blank" rel="noopener noreferrer"><i class="document"></i><b>{project.name}</b><span>{label}</span><em>↗</em></a>];
            }
            return signals.map((signal, index) => {
              const isCi = signal.kind === "ci";
              const isArtifact = signal.kind === "artifact";
              return <a class={`signal-row ${signal.tone}`} href={signal.href} target="_blank" rel="noopener noreferrer" data-ci-status={isCi ? repoStatus[project.slug]?.ci.status : undefined} data-ci-run-at={isCi ? repoStatus[project.slug]?.ci.runAt : undefined} data-artifact-status={isArtifact ? repoStatus[project.slug]?.artifact.status : undefined} data-artifact-expires-at={isArtifact ? repoStatus[project.slug]?.artifact.artifacts?.find((item) => !item.expired)?.expiresAt : undefined}><i class={signal.tone === "pass" || signal.tone === "release" ? "ok" : signal.tone === "failure" ? "failure" : "document"}></i><b>{index === 0 ? project.name : `${project.name} · 其他记录`}</b><span data-signal-label>{signal.label}</span><em>↗</em></a>;
            });
          })}
        </div>
      </section>

      <section class="build-log section-shell" id="log" aria-labelledby="log-title" data-section="03">
        <div class="section-heading reveal">
          <div><p class="section-index">03 / RECENT UPDATES</p><h2 id="log-title">最近更新</h2></div>
          <p>我最近发布、测试或复盘的内容。</p>
        </div>
        <div class="log-grid">
          {buildLog.map((item) => (
            <a class="log-entry reveal" href={item.href} target="_blank" rel="noreferrer">
              <div><span>{item.type}</span><time datetime={item.date.replaceAll(".", "-")}>{item.date}</time></div>
              <h3>{item.title}</h3><p>{item.text}</p><i>READ ↗</i>
            </a>
          ))}
        </div>
      </section>

      <section class="closing section-shell reveal">
        <p class="eyebrow">YI盘 / CURRENT PROGRESS</p>
        <h2><span class="statement-line">想知道 Yi盘</span><span class="statement-line"><em>现在做到哪一步？</em></span></h2>
        <p>公开仓库记录已确认的功能、已知限制和开发进度。</p>
        <a class="button primary" href="https://github.com/rongyishuaige7/yipan-showcase" target="_blank" rel="noreferrer">查看 Yi盘进展 <span>↗</span></a>
      </section>
    </main>

    <footer>
      <div><b>RONGYI</b><span>Yi盘 · Hangzhou</span></div>
      <p>Yi盘、桌面工具与硬件项目。</p>
      <span>© {new Date().getFullYear()} @rongyishuaige7</span>
    </footer>

    <script>
      import { refreshTimeSensitiveSignals } from "../scripts/status-freshness";
      refreshTimeSensitiveSignals();

      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const reveals = document.querySelectorAll(".reveal");
      reveals.forEach((el, index) => {
        if (!reduced && index < 3) el.classList.add("enter");
      });
      const header = document.querySelector("[data-header]");
      const onScroll = () => header?.classList.toggle("is-scrolled", window.scrollY > 40);
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
    </script>
  </body>
</html>
